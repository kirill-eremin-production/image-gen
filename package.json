{
  "name": "narisuy",
  "version": "1.0.0",
  "description": "AI image and video generator",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 50911",
    "build": "next build",
    "start": "next start -p 50911",
    "lint": "eslint",
    "electron:dev": "electron .",
    "electron:build": "node scripts/clean-electron-build.mjs && next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && electron-builder && npm run electron:install",
    "electron:install": "node scripts/install-built-app.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^6.0.2"
  },
  "build": {
    "appId": "com.kilo.narisuy",
    "productName": "Narisuy",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      }
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "assets/icon.png",
      "target": ["dmg"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}
